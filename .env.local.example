# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Codef (샌드박스 미혼 검증)
CODEF_CLIENT_ID=
CODEF_CLIENT_SECRET=
CODEF_PUBLIC_KEY=

# 개발 데모용: Codef 키 없을 때 미혼 검증 자동 통과
MOCK_VERIFICATION=true

# (선택) /api/health 자동 점검용 비밀번호 — GitHub Secrets에도 같은 값 등록
# HEALTH_CHECK_SECRET=
